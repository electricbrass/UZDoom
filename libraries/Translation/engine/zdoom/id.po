msgid "QUITMSG1"
msgstr ""
"Tolong jangan pergi, masih ada\n"
"setan yang perlu dibakar!"

msgid "QUITMSG2"
msgstr ""
"Ayo kabur—ini mulai\n"
"jadi pembantaian!"

msgid "QUITMSG3"
msgstr ""
"Aku tidak akan pergi jika jadi kamu.\n"
"DOS jauh lebih buruk."

msgid "QUITMSG4"
msgstr ""
"Kamu mau bilang kamu lebih suka DOS\n"
"daripada aku, kan?"

msgid "QUITMSG5"
msgstr ""
"Jangan pergi dulu—ada\n"
"setan di balik sudut itu!"

msgid "QUITMSG6"
msgstr ""
"Tau nggak, lain kali kamu masuk ke sini\n"
"aku bakal panggang kamu."

msgid "QUITMSG7"
msgstr "Silakan pergi. lihat apa aku peduli."

# More info here.
msgid "QUITMSG8"
msgstr ""
"Mau keluar?\n"
"Maka, kau telah kehilangan seperdelapan!"

# A “dimensional shambler” is a creature appearing in the works of H. P.
# Lovecraft.
msgid "QUITMSG9"
msgstr ""
"Jangan pergi sekarang, ada\n"
"dimensional shambler yang menunggu\n"
"di prompt DOS!"

msgid "QUITMSG10"
msgstr ""
"Keluarlah dari sini dan kembalilah\n"
"ke program-program membosankanmu."

msgid "QUITMSG11"
msgstr ""
"Kalau aku atasanmu, aku akan\n"
"tantang kamu deathmatch sekarang juga!"

msgid "QUITMSG12"
msgstr ""
"Dengar, bung. kalau kamu pergi sekarang\n"
"kamu kehilangan jumlah korbanmu!"

msgid "QUITMSG13"
msgstr ""
"Pergi saja. Kalau kamu kembali,\n"
"aku akan menunggu dengan tongkat."

msgid "QUITMSG14"
msgstr ""
"Untung aku tidak memukulmu\n"
"karena berpikir untuk pergi."

msgid "QUITMSG15"
msgstr ""
"Mau ke mana kamu?!\n"
"Bagaimana dengan pemberontakannya?"

msgid "QUITMSG16"
msgstr ""
"Carnage interruptus…\n"
"Sungguh menggoda!"

msgid "QUITMSG17"
msgstr ""
"Tapi kamu adalah harapan\n"
"—satu-satunya kesempatanku!!"

msgid "QUITMSG18"
msgstr "Tidak ada yang bisa pergi begitu saja dari Blackbird."

msgid "QUITMSG19"
msgstr "Kukira kamu berbeda…"

msgid "QUITMSG20"
msgstr "Baiklah! tinggal bunuh dan kabur!"

msgid "QUITMSG21"
msgstr ""
"Kamu boleh keluar…\n"
"tapi kamu tidak bisa bersembunyi…"

msgid "QUITMSG22"
msgstr ""
"Hahh, ada apa?\n"
"Mama bilang sudah waktunya makan?"

msgid "QUITMSG23"
msgstr ""
"Jangan keluar sekarang, masih ada\n"
"flemoid yang berkeliaran!"

msgid "QUITMSG24"
msgstr ""
"Jangan menyerah—para flemoid akan\n"
"mendapat keunggulan!"

msgid "QUITMSG25"
msgstr ""
"Jangan pergi sekarang.\n"
"Kami butuh bantuanmu!"

msgid "QUITMSG26"
msgstr ""
"Semoga kamu hanya istirahat sebentar\n"
"untuk makan Chex® party mix."

msgid "QUITMSG27"
msgstr ""
"Jangan keluar sekarang!\n"
"Kami butuh bantuanmu!"

msgid "QUITMSG28"
msgstr ""
"Jangan tinggalkan\n"
"Federasi Sereal Antargalaksi!"

msgid "QUITMSG29"
msgstr ""
"Pejuang Chex® sejati\n"
"tidak akan menyerah secepat ini!"

