msgid "DOSY"
msgstr "(Pritisnite Y za izlazak)"

msgid "QUITMSG1"
msgstr ""
"Molim vas, nemojte ići, ima još\n"
"demona za ispeći!"

msgid "QUITMSG2"
msgstr ""
"Pođimo—ovo se pretvara\n"
"u krvoproliće!"

msgid "QUITMSG3"
msgstr ""
"Ne bih otišao na tvom mjestu.\n"
"DOS je mnogo gori."

msgid "QUITMSG4"
msgstr ""
"Pokušavate reći da vam se DOS\n"
"više sviđa od mene, zar ne?"

msgid "QUITMSG5"
msgstr ""
"Ne odlazite još—iza tog\n"
"ugla je demon!"

msgid "QUITMSG6"
msgstr ""
"Znaš, sljedeći put kad dođeš ovdje,\n"
"isprobat ću te."

msgid "QUITMSG7"
msgstr "Samo idi. Pa vidi da li mi je stalo."

msgid "QUITMSG8"
msgstr ""
"Hoćeš da odustaneš?\n"
"Onda si izgubio osminu!"

msgid "QUITMSG9"
msgstr ""
"Ne idite sada, dimenzionalni\n"
"šambler čeka\n"
"na DOS promptu!"

msgid "QUITMSG10"
msgstr ""
"Odlazi i vrati se svojim\n"
"dosadnim programima."

msgid "QUITMSG11"
msgstr ""
"Da sam ti šef, odmah bih\n"
"te ubio u smrtoutakmici!"

msgid "QUITMSG12"
msgstr ""
"Slušaj, druže. Ako odeš\n"
"sad, gubiš svoj broj ubijenih!"

msgid "QUITMSG13"
msgstr ""
"Samo idi. Kad se vratiš,\n"
"čekat ću te s palicom."

msgid "QUITMSG14"
msgstr ""
"Sreća te ne šakiram što\n"
"si razmišljao o odlasku."

msgid "QUITMSG15"
msgstr ""
"Kuda ideš?!\n"
"A pobuna?"

msgid "QUITMSG16"
msgstr ""
"Pokolj prekinut…\n"
"Kakvo izazivanje!"

msgid "QUITMSG17"
msgstr ""
"Ali ti si nada\n"
"—moja jedina šansa!!"

msgid "QUITMSG18"
msgstr "Niko ne napušta Blackbird."

msgid "QUITMSG19"
msgstr "Mislio sam da si drugačiji…"

msgid "QUITMSG20"
msgstr "U redu! Samo ubij i bježi!"

msgid "QUITMSG21"
msgstr ""
"Možeš prestati…\n"
"ali se ne možeš sakriti…"

msgid "QUITMSG22"
msgstr ""
"Haaa, šta je bilo? Mama\n"
"kaže da je vrijeme za večeru?"

msgid "QUITMSG23"
msgstr ""
"Ne odustaj sada, još uvijek\n"
"ima flemoida na slobodi!"

msgid "QUITMSG24"
msgstr ""
"Ne odustaj—flemoidi\n"
"će uzeti prevagu!"

msgid "QUITMSG25"
msgstr ""
"Ne odlazi sada.\n"
"Trebamo tvoju pomoć!"

msgid "QUITMSG26"
msgstr ""
"Nadam se da samo pravite\n"
"pauzu za Chex® party mix."

msgid "QUITMSG27"
msgstr ""
"Ne odustajte sada!\n"
"Trebamo vašu pomoć!"

msgid "QUITMSG28"
msgstr ""
"Ne napuštaj Intergalaktičku\n"
"federaciju žitarica!"

msgid "QUITMSG29"
msgstr ""
"Pravi Chex® Ratnik ne bi\n"
"odustao tako brzo!"

