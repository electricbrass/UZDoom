msgid "TXT_DLG_SCRIPT23_D15160_IFYOU"
msgstr "Ako imaš toliko vremena za gubiti, pokušaj pronaći plavi kalež. Moja istraživanja o Redu sugeriraju da su ga negdje sakrili u proizvodnom sektoru tvornice. Ovaj artefakt bi mi bio od velike vrijednosti, pa mi ga donesi i pomoći ću ti."

msgid "TXT_DLG_SCRIPT23_D16676_YOUFO"
msgstr "Pronašao si plavi kalež! U redu, daj mi ga prvo, pa ćemo razmijeniti."

msgid "TXT_RPLY0_SCRIPT23_D16676_TAKEI"
msgstr "Uzmi, ionako donosi nesreću."

msgid "TXT_RPLY1_SCRIPT23_D16676_SCREW"
