msgid "TXT_RYES0_SCRIPT32_D3032_IWASF"
msgstr "Namjestili su mi."

msgid "TXT_DLG_SCRIPT32_D4548_HARRI"
msgstr "Harris je rekao da sam planirao ubiti guvernera. Nikada ne bih naudio nikome."

msgid "TXT_DLG_SCRIPT33_D0_BECAR"
msgstr "Pazi se tamo vani."

# MAP33: Guy next to Norwall Prison.
msgid "TXT_DLG_SCRIPT33_D1516_SAYFR"
msgstr "Hej prijatelju, pomoći ću ti ako mi pomogneš. Daj mi pet zlatnika i reći ću ti šta znam."

msgid "TXT_RPLY0_SCRIPT33_D1516_HERES"
msgstr "Evo zlata."

msgid "TXT_RYES0_SCRIPT33_D1516_IFYOU"
msgstr "Ako nekoga udariš, nećeš pokrenuti alarme."

msgid "TXT_RNO0_SCRIPT33_D1516_IWONT"
msgstr "Neću ti ništa reći besplatno!"

msgid "TXT_DLG_SCRIPT33_D3032_IVEAL"
msgstr "Već sam ti rekao ono što znam."

# MAP33: Weapons.
msgid "TXT_DLG_SCRIPT33_D4548_HELLO"
msgstr "Zdravo prijatelju. Šta mogu da ti donesem?"

msgid "TXT_RPLY0_SCRIPT33_D4548_ELECT"
msgstr "Električni vijci"

msgid "TXT_RYES0_SCRIPT33_D4548_ONEQU"
msgstr "To je jedna svađa."

msgid "TXT_RNO0_SCRIPT33_D4548_YOURE"
msgstr "Nemaš para!"

msgid "TXT_RPLY1_SCRIPT33_D4548_10ROU"
msgstr "Klip metaka"

msgid "TXT_RYES1_SCRIPT33_D4548_HERES"
msgstr "Evo tvog streljiva"

msgid "TXT_RNO1_SCRIPT33_D4548_SORRY"
msgstr "Žao mi je, nema novca, nema metaka."

msgid "TXT_RPLY2_SCRIPT33_D4548_50ROU"
msgstr "Kutija za municiju"

msgid "TXT_RYES2_SCRIPT33_D4548_HEREY"
msgstr "Evo"

msgid "TXT_RNO2_SCRIPT33_D4548_YOUDO"
msgstr "Nemate dovoljno zlata!"

msgid "TXT_RPLY3_SCRIPT33_D4548_AMMOS"
msgstr "Futrola za municiju"

msgid "TXT_RYES3_SCRIPT33_D4548_THANK"
msgstr "Hvala, ima li još nešto?"

msgid "TXT_RNO3_SCRIPT33_D4548_YOUCA"
msgstr "Ne možete si to priuštiti, dobar dan."

# MAP33: Armory
msgid "TXT_DLG_SCRIPT33_D6064_WELCO"
msgstr "Dobrodošli. Šta vam mogu pokazati?"

msgid "TXT_RPLY0_SCRIPT33_D6064_ENVIR"
msgstr "Žalba na zaštitu okoliša"

msgid "TXT_RYES0_SCRIPT33_D6064_HEREY"
msgstr "Evo te."

msgid "TXT_RNO0_SCRIPT33_D6064_YOUDO"
msgstr "Nemate dovoljno novca za to."

msgid "TXT_RPLY1_SCRIPT33_D6064_LEATH"
msgstr "Kožni oklop."

msgid "TXT_RYES1_SCRIPT33_D6064_HEREY"
msgstr "Evo te."

msgid "TXT_RNO1_SCRIPT33_D6064_PERHA"
msgstr "Možda neki drugi put?"

msgid "TXT_RPLY2_SCRIPT33_D6064_METAL"
msgstr "Metalni oklop"

msgid "TXT_RYES2_SCRIPT33_D6064_WEARI"
msgstr "Nosite ga u zdravlju."

msgid "TXT_RNO2_SCRIPT33_D6064_COMEB"
msgstr "Vratite se kad budete mogli."

# MAP33: Hospital
msgid "TXT_DLG_SCRIPT33_D7580_HOWMA"
msgstr "Kako vam mogu pomoći?"

msgid "TXT_RPLY0_SCRIPT33_D7580_MEDPA"
msgstr "Medicinski flaster"

msgid "TXT_RYES0_SCRIPT33_D7580_HERES"
msgstr "Evo vašeg kompleta za zakrpe."

msgid "TXT_RNO0_SCRIPT33_D7580_YOUNE"
msgstr "Za to ti treba 10 zlata."

msgid "TXT_RPLY1_SCRIPT33_D7580_FIELD"
msgstr "Terenski hirurški komplet"

msgid "TXT_RYES1_SCRIPT33_D7580_THANK"
msgstr "Hvala vam."

msgid "TXT_RNO1_SCRIPT33_D7580_IWISH"
msgstr "Volio bih da ih mogu pokloniti, ali koštaju 25 zlata."

msgid "TXT_RPLY2_SCRIPT33_D7580_HEALI"
msgstr "Iscjeljenje"

msgid "TXT_RYES2_SCRIPT33_D7580_THERE"
msgstr "Evo. Čuvaj se sada."

msgid "TXT_RNO2_SCRIPT33_D7580_WELLM"
msgstr "Pa, možda si možeš priuštiti neke medicinske flastere?"

# MAP33: Barkeep.
msgid "TXT_DLG_SCRIPT33_D9096_HELLO"
msgstr "Zdravo prijatelju, nisam te ranije vidio ovdje. Sve što mogu reći je da bih bio oprezan na tvom mjestu, puno se toga dešava i bolje ti je da ne stojiš na putu."

msgid "TXT_RPLY0_SCRIPT33_D9096_INFOR"
msgstr "Informacije"

msgid "TXT_RYES0_SCRIPT33_D9096_THESE"
msgstr "Kanalizacija sadrži više od samo pacova i robota."

msgid "TXT_RNO0_SCRIPT33_D9096_HEYAG"
msgstr "Hej, čovjek mora zaraditi nešto novca. Misliš li da ovi šašuni dobro ostavljaju napojnice?"

msgid "TXT_DLG_SCRIPT33_D10612_BACKA"
msgstr "Ponovo si tu, ha? Pa barem znaš dovoljno da sačuvaš svoju kožu netaknutom. Šta mogu učiniti za tebe sada?"

msgid "TXT_RPLY0_SCRIPT33_D10612_MOREI"
msgstr "Više informacija"

msgid "TXT_RYES0_SCRIPT33_D10612_THEGO"
msgstr "Guverner je jednostavan podsjetnik na utjecaj Reda."

msgid "TXT_RNO0_SCRIPT33_D10612_COMEB"
msgstr "Vratite se ako promijenite mišljenje."

msgid "TXT_DLG_SCRIPT33_D12128_WELLY"
msgstr "Pa, postavljaš puno pitanja za nekoga ko je već toliko dugo živ. Ali nema problema, radije bih razgovarao s nekim poput tebe nego s većinom ovih."

msgid "TXT_RPLY0_SCRIPT33_D12128_MOREI"
msgstr "Više informacija."

msgid "TXT_RYES0_SCRIPT33_D12128_THERE"
msgstr "Red je mnogo više od onoga što se ovdje događa."

msgid "TXT_RNO0_SCRIPT33_D12128_COMEB"
msgstr "Vratite se ako promijenite mišljenje."

msgid "TXT_DLG_SCRIPT33_D13644_THATS"
msgstr "To je to, prijatelju, bunar znanja je iskorišten. Ionako sam ti rekao više nego što sam trebao."

# MAP33: Harris (beginning).
msgid "TXT_DLG_SCRIPT33_D15160_HARDT"
msgstr "Teško je kupovati nove igračke… kad si bez novca. Obavi za mene jednu malu poslicu i dobit ćeš više nego što bi ikada mogao potrošiti. Učinit ću te bogatašem."

msgid "TXT_RPLY0_SCRIPT33_D15160_IGOTN"
msgstr "Nemam ništa bolje za raditi."

msgid "TXT_RPLY1_SCRIPT33_D15160_NOTHA"
msgstr "Ne, hvala."

msgid "TXT_RYES1_SCRIPT33_D15160_NOBOD"
msgstr "Niko ne odlazi od mene!"

msgid "TXT_DLG_SCRIPT33_D16676_GOODC"
msgstr "Dobar izbor. Svetište Reda uz rijeku je njihova neslužbena komora za mučenje. U njemu je skriven zlatni kalež. Uzmi ga, nađi se sa mnom u krčmi i uzmi svoju nagradu."

msgid "TXT_RPLY0_SCRIPT33_D16676_HOWAM"
msgstr "Kako to trebam uraditi?"

msgid "TXT_RPLY1_SCRIPT33_D16676_LETME"
msgstr "Dopusti mi da razmislim o tome."

msgid "TXT_RYES1_SCRIPT33_D16676_SORRY"
msgstr "Žao mi je, nema drugog puta. Oh, stražari, ubijte ga!"

msgid "TXT_DLG_SCRIPT33_D18192_HERES"
msgstr "Evo samostrela, samo nišanite ravno i -- splat! --. Zapamtite, uzmite otmjeni pehar i nađite se sa mnom u krčmi."

msgid "TXT_RPLY0_SCRIPT33_D18192_ILLSE"
msgstr "Vidimo se tamo."

msgid "TXT_DLG_SCRIPT33_D19708_WHATA"
msgstr "Šta čekate? Ne brinite, ja ću počistiti tijela, samo mi donesite taj kalež!"

msgid "TXT_DLG_SCRIPT33_D21224_GUARD"
msgstr "Čuvari! Ubijte izdajnika!"

# MAP33: Harris (tavern).
msgid "TXT_DLG_SCRIPT33_D22740_HEYIK"
msgstr "Hej, znam šta misliš, nekako izgleda kao podmetanje, nikad ne bih to uradio takvoj mašini za ubijanje, stvarno mislim. Uf, sva ova frka zbog jedne šolje, čudno. Sad se pripremi, zlato i slava, kao što sam obećao. Uzmi ovaj ključ i sam guverner će te nagraditi."

msgid "TXT_RPLY0_SCRIPT33_D22740_GREAT"
msgstr "Sjajno, jedva čekam!"

# (if accepting without having the chalice)
msgid "TXT_RNO0_SCRIPT33_D22740_NOCHA"
msgstr "Nema kaleža, nema novca!"

msgid "TXT_RPLY1_SCRIPT33_D22740_ILLKE"
msgstr "Održat ću kalež, hvala."

msgid "TXT_RYES1_SCRIPT33_D22740_KEEPI"
msgstr "Zadržati? Mislim da ne!"

msgid "TXT_DLG_SCRIPT33_D24256_WHATA"
msgstr "Šta čekate? Sam guverner će vas nagraditi."

msgid "TXT_DLG_SCRIPT33_D25772_DIETR"
msgstr "O izdajniče! "

# MAP33: Mourel.
msgid "TXT_DLG_SCRIPT33_D27288_SOYOU"
msgstr "Dakle, ti si budala koja je ukrala kalež? Uhapsiću te kao pobunjeničkog lopova… čime ću unaprijediti svoj položaj u Redu. Kako je to biti nesvjesna pijun?"

msgid "TXT_RPLY0_SCRIPT33_D27288_ITSUC"
msgstr "Sranje je!"

msgid "TXT_RYES0_SCRIPT33_D27288_FORYO"
msgstr "Za tebe da."

msgid "TXT_RPLY1_SCRIPT33_D27288_HARRI"
msgstr "Harris mi je obećao novac!"

msgid "TXT_RYES1_SCRIPT33_D27288_TOOBA"
msgstr "Šteta. Jedino što ćeš dobiti je smrt!"

msgid "TXT_DLG_SCRIPT33_D28804_WEREG"
msgstr "Ubit ćemo te!"

msgid "TXT_DLG_SCRIPT33_D30320_GETOU"
msgstr "Makni se odavde!"

# MAP33: Green acolytes (beginning).
msgid "TXT_DLG_SCRIPT33_D31836_WEREG"
msgstr "Ubit ćemo te!"

# MAP33: Yellow acolytes.
msgid "TXT_DLG_SCRIPT33_D33352_GETOU"
msgstr "Makni se odavde!"

# MAP34: Barracks.
msgid "TXT_DLG_SCRIPT34_D0_WHATA"
msgstr "Kakvo savršeno mjesto za nas, ispod stare gradske vijećnice. Red misli da su nas uništili, ali sve je to bio samo podsjetnik na to šta se može dogoditi kad postaneš nepažljiv. "

# MAP34
msgid "TXT_DLG_SCRIPT34_D1516_TALKT"
msgstr "Razgovaraj s Macilom, on će ti moći pomoći."

# MAP34: Barracks.
msgid "TXT_DLG_SCRIPT34_D3032_IVEHE"
msgstr "Čuo sam da će Macil uskoro ponovo nešto započeti. Nakon posljednjeg fijaska trebamo veliki hit. Još jedan takav i bit ćemo preslabi da nastavimo."

msgid "TXT_DLG_SCRIPT34_D4548_AFEWO"
msgstr "Par ovih bačvi bačenih u njihov vodeni sistem trebalo bi malo izjednačiti izglede. "

# MAP34: Gerald.
# (Except for row 1335, everything in rows 1323-1343 is identical to 725-745)
msgid "TXT_DLG_SCRIPT34_D6064_IMWOR"
msgstr "Radim na nečemu što će nam dati prednost. Povećat će tvoju izdržljivost i potpuno te razbuditi. Gotovo sam otklonio sve greške. Mogu li ti pomoći? "

msgid "TXT_RPLY0_SCRIPT34_D6064_PATCH"
msgstr "Zalijepi me."

msgid "TXT_RYES0_SCRIPT34_D6064_BOYYO"
msgstr "Čovječe, ti si pravi nered. Vidjet ću šta mogu učiniti."

msgid "TXT_RPLY1_SCRIPT34_D6064_STAMI"
msgstr "Implantat izdržljivosti?"

msgid "TXT_RYES1_SCRIPT34_D6064_ALLRI"
msgstr "U redu, ovo neće potrajati ni trenutak."

msgid "TXT_RNO1_SCRIPT34_D6064_ITSNO"
msgstr "Još nije gotovo."

msgid "TXT_DLG_SCRIPT34_D7580_HEYIM"
msgstr "Hej, radim na ažuriranoj verziji tvog implanta. Ima li još nešto što mogu učiniti?"

msgid "TXT_RPLY0_SCRIPT34_D7580_PATCH"
msgstr "Zalijepi me."

msgid "TXT_RYES0_SCRIPT34_D7580_WELLA"
msgstr "Pa barem vidiš akciju."

msgid "TXT_RPLY1_SCRIPT34_D7580_IMPLA"
msgstr "Nadogradnja implantata?"

msgid "TXT_RYES1_SCRIPT34_D7580_GOODT"
msgstr "Bolje da bude dobro, nikad ne može biti previše sigurno."

msgid "TXT_RNO1_SCRIPT34_D7580_IMALM"
msgstr "Skoro sam gotov, ali još nisam sasvim."

msgid "TXT_DLG_SCRIPT34_D9096_ALLRI"
msgstr "U redu, ovo je to. Gotovo sve radi savršeno. Ostalo je još nekoliko problema za riješiti, treba li ti još nešto? "

msgid "TXT_RPLY0_SCRIPT34_D9096_PATCH"
msgstr "Zalijepi me."

msgid "TXT_RYES0_SCRIPT34_D9096_WHATH"
msgstr "Šta si pokušavao uraditi? Da se suprotstaviš krstašu?"

msgid "TXT_RPLY1_SCRIPT34_D9096_IMPLA"
msgstr "Nadogradnja implantata?"

msgid "TXT_RYES1_SCRIPT34_D9096_THATS"
msgstr "To bi trebalo biti dovoljno za vas."

msgid "TXT_RNO1_SCRIPT34_D9096_LETME"
msgstr "Dopusti mi da prvo provedem još nekoliko testova."

msgid "TXT_DLG_SCRIPT34_D10612_THATS"
msgstr "To je sve što trenutno mogu učiniti s implantatom. Možda će se malo zacijeliti?"

msgid "TXT_RPLY0_SCRIPT34_D10612_YEAH"
msgstr "Da."

msgid "TXT_RYES0_SCRIPT34_D10612_BOYYO"
msgstr "Čovječe, ti si pravi nered. Vidjet ću šta mogu učiniti."

# MAP34: Feris (identical to rows 746-768, except for row 1357).
msgid "TXT_DLG_SCRIPT34_D12128_WHATC"
msgstr "Šta mogu učiniti za vas?"

msgid "TXT_RPLY0_SCRIPT34_D12128_IMOUT"
msgstr "Nemam više metaka."

msgid "TXT_RYES0_SCRIPT34_D12128_HERES"
msgstr "Evo ti municije. Nemoj je bacati."

msgid "TXT_RPLY1_SCRIPT34_D12128_TEACH"
msgstr "Nauči me."

msgid "TXT_RYES1_SCRIPT34_D12128_ALLRI"
msgstr "U redu, samo ću ti pokazati nekoliko malih savjeta."

msgid "TXT_RNO1_SCRIPT34_D12128_YOURE"
msgstr "Još nisi spreman."

msgid "TXT_DLG_SCRIPT34_D13644_BACKA"
msgstr "Ponovo? Šta ti treba?"

msgid "TXT_RPLY0_SCRIPT34_D13644_IMOUT"
msgstr "Nemam više metaka."

msgid "TXT_RYES0_SCRIPT34_D13644_HERES"
msgstr "Evo ti municije. Nemoj je bacati."

msgid "TXT_RNO0_SCRIPT34_D13644_YOUVE"
msgstr "Imaš dovoljno municije."

msgid "TXT_RPLY1_SCRIPT34_D13644_TEACH"
msgstr "Nauči me."

msgid "TXT_RYES1_SCRIPT34_D13644_ALLRI"
msgstr "U redu, ovo bi te trebalo izdržati neko vrijeme."

msgid "TXT_RNO1_SCRIPT34_D13644_SORRY"
msgstr "Žao mi je, ne mogu. Samo izvršavam Macilove naredbe."

msgid "TXT_DLG_SCRIPT34_D15160_WELLW"
msgstr "Pa šta je to, municija ili obuka? Jedva čekam da stavim ruke na ta nova oružja koja smo zaplijenili. Kad završim s njima, moći ću početi obučavati sve ostale."

msgid "TXT_RPLY0_SCRIPT34_D15160_IMOUT"
msgstr "Ostala mi je municija."

msgid "TXT_RYES0_SCRIPT34_D15160_HERES"
msgstr "Evo ti municije. Nemoj je bacati."

msgid "TXT_RNO0_SCRIPT34_D15160_YOUVE"
msgstr "Imaš dovoljno municije."

msgid "TXT_RPLY1_SCRIPT34_D15160_TEACH"
msgstr "Nauči me."

msgid "TXT_RYES1_SCRIPT34_D15160_OKTAK"
msgstr "U redu. Uzmi ono što si naučio i pokaži tim bastardima iz Reda put u pakao."

msgid "TXT_RNO1_SCRIPT34_D15160_COMEB"
msgstr "Vratite se kasnije, kad Macil kaže da je vrijeme."

msgid "TXT_DLG_SCRIPT34_D16676_IVETA"
msgstr "Naučio sam te svemu što trenutno mogu. Daj mi malo vremena da isprobam nova oružja. Osim ako ti municija nije ponestala."

msgid "TXT_RPLY0_SCRIPT34_D16676_YESIA"
msgstr "Da, jesam."

msgid "TXT_RYES0_SCRIPT34_D16676_HEREY"
msgstr "Evo."

# MAP34: Upstairs.
# (Identical to row 769)
msgid "TXT_DLG_SCRIPT34_D18192_DONTG"
msgstr "Nemoj se previše igrati oružjem u gradu, aktivirat ćeš alarm i oni će početi slati straže iz dvorca."

# (Identical to row 770)
msgid "TXT_DLG_SCRIPT34_D19708_WELCO"
msgstr "Dobrodošli, uvijek nam dobro dođe dodatna pomoć."

# (Similar to row 771)
msgid "TXT_DLG_SCRIPT34_D21224_WHENI"
msgstr "Kad sam još bio u akciji, imali smo priliku pregledati akolita prije nego što su stigle pojačanja, oni nisu ljudi, kažem ti."

# MAP34: Downstairs.
# (Identical to row 772)
msgid "TXT_DLG_SCRIPT34_D22740_WERET"
msgstr "Pokušavamo pronaći gdje se nalaze mehanizmi kapija dvorca, ali do sada nismo imali sreće."

# (Similar to row 773)
msgid "TXT_DLG_SCRIPT34_D24256_DONTG"
msgstr "Nemoj da te uhvate. Čuo sam užasne priče o tome šta rade našim ljudima nakon što ih zatvore. Oni jednostavno nestanu, bez traga, ništa. "

# (Similar to row 774)
msgid "TXT_DLG_SCRIPT34_D25772_HERES"
msgstr "Evo savjeta: ako ikada vidiš bilo kojeg od limenih vojnika Reda, bježi u drugom smjeru. Posebno ne volim Reavere, ta stvorenja su prokleto brza!"

# MAP34: Macil.
msgid "TXT_DLG_SCRIPT34_D27288_WELCO"
msgstr "Dobrodošli u posljednji tračak nade. Samo mi imamo slobodnu volju da se suprotstavimo Redu. Imamo najoštrije naučne umove i mnogo sposobnih tijela. Ali nam nedostaje onaj pravi rješavač problema koji će nam dati prednost koju trebamo."

msgid "TXT_RPLY0_SCRIPT34_D27288_WHATW"
msgstr "Šta ću morati da uradim? "

msgid "TXT_DLG_SCRIPT34_D28804_HELPU"
msgstr "Pomozite nam. Pomozite nam ukrasti njihovu tehnologiju. Oslobodite naše saborce. Borite se protiv ovih izopačenih psihopata do smrti. Molim vas da riskirate svoj život za istinu."

msgid "TXT_RPLY0_SCRIPT34_D28804_IMWIT"
msgstr "Slažem se s tobom!"

msgid "TXT_DLG_SCRIPT34_D30320_GOODB"
msgstr "Dobro. Blackbird će i dalje biti tvoj vodič. Prilično joj se svidioš. Zajedno morate otkriti tajne Reda i njihovih neljudskih slugu. Postoji prisustvo koje vreba tik izvan našeg razumijevanja i koje usmjerava njihov teror. Uđi unutra i porazi ih. "

msgid "TXT_RPLY0_SCRIPT34_D30320_LETME"
msgstr "Pustite me na njih!"

msgid "TXT_RYES0_SCRIPT34_D30320_THATS"
msgstr "To je duh."

msgid "TXT_DLG_SCRIPT34_D31836_WELCO"
msgstr "Dobrodošao, prijatelju!"

msgid "TXT_RANDOM_PEASANT_01"
msgstr "Molim te, nemoj me povrijediti."

msgid "TXT_RANDOM_PEASANT_02"
msgstr "Ako me želiš povrijediti, stvarno ne vrijedim tog truda."

msgid "TXT_RANDOM_PEASANT_03"
msgstr "Ne znam ništa."

msgid "TXT_RANDOM_PEASANT_04"
msgstr "Otiđi ili ću pozvati stražu!"

msgid "TXT_RANDOM_PEASANT_05"
msgstr "Ponekad poželim da svi ti pobunjenici nauče svoje mjesto i prestanu s tim besmislicama."

msgid "TXT_RANDOM_PEASANT_06"
msgstr "Samo me ostavi na miru, u redu?"

msgid "TXT_RANDOM_PEASANT_07"
msgstr "Nisam siguran, ali ponekad mislim da poznajem neke od akolita."

msgid "TXT_RANDOM_PEASANT_08"
msgstr "Red je ovdje sve prilično dobro zaključao."

msgid "TXT_RANDOM_PEASANT_09"
msgstr "Nema šanse da je ovo samo sigurnosna snaga."

msgid "TXT_RANDOM_PEASANT_10"
msgstr "Čuo sam da je Red stvarno nervozan zbog akcija Fronta ovdje."

msgid "TXT_RANDOM_REBEL_01"
msgstr "Nema šanse da se Red usprotivi nama."

msgid "TXT_RANDOM_REBEL_02"
msgstr "Skoro smo spremni za napad. Macilovi planovi se ostvaruju."

msgid "TXT_RANDOM_REBEL_03"
msgstr "Svi smo uz tebe, ne brini."

msgid "TXT_RANDOM_REBEL_04"
msgstr "Nemoj se previše približavati nijednom od tih velikih robota. Otopit će te za otpad!"

msgid "TXT_RANDOM_REBEL_05"
msgstr "Dan naše slave uskoro će doći, i oni koji nam se protive bit će zdrobljeni!"

msgid "TXT_RANDOM_REBEL_06"
msgstr "Nemoj se previše opustiti. Još uvijek imamo puno posla."

msgid "TXT_RANDOM_REBEL_07"
msgstr "Macil kaže da si nova nada. Imaj to na umu."

msgid "TXT_RANDOM_REBEL_08"
msgstr "Kad jednom porazimo ove šarlatane, moći ćemo obnoviti ovaj svijet onako kako treba."

msgid "TXT_RANDOM_REBEL_09"
msgstr "Zapamti da se ne boriš samo za sebe, nego i za sve ovdje i vani."

msgid "TXT_RANDOM_REBEL_10"
msgstr "Sve dok nas je barem jedan preostao, pobijedit ćemo."

msgid "TXT_RANDOM_AGUARD_01"
msgstr "Idi dalje, seljačino."

msgid "TXT_RANDOM_AGUARD_02"
msgstr "Slijedi istinsku vjeru, tek tada ćeš početi razumjeti."

msgid "TXT_RANDOM_AGUARD_03"
msgstr "Samo kroz smrt se može istinski ponovo roditi."

msgid "TXT_RANDOM_AGUARD_04"
msgstr "Ne zanimaju me tvoje besmislene gluposti."

msgid "TXT_RANDOM_AGUARD_05"
msgstr "Da sam htio razgovarati s tobom, rekao bih ti to."

msgid "TXT_RANDOM_AGUARD_06"
msgstr "Idi i nerviraj nekog drugog!"

msgid "TXT_RANDOM_AGUARD_07"
msgstr "Nastavi se kretati!"

msgid "TXT_RANDOM_AGUARD_08"
msgstr "Ako se alarm oglasi, samo ostani izvan našeg puta!"

msgid "TXT_RANDOM_AGUARD_09"
msgstr "Red će očistiti svijet i uvesti ga u novu eru."

msgid "TXT_RANDOM_AGUARD_10"
msgstr "Problem? Ne, mislio sam da nema."

msgid "TXT_RANDOM_BEGGAR_01"
msgstr "Milostinja za siromašne?"

msgid "TXT_RANDOM_BEGGAR_02"
msgstr "Šta gledaš, surfacer?"

msgid "TXT_RANDOM_BEGGAR_03"
msgstr "Ne biste imali viška hrane, zar ne?"

msgid "TXT_RANDOM_BEGGAR_04"
msgstr "Vi, površinski ljudi, nikada nas nećete razumjeti."

msgid "TXT_RANDOM_BEGGAR_05"
msgstr "Ha, stražari nas ne mogu pronaći. Ti idioti čak ni ne znaju da postojimo."

msgid "TXT_RANDOM_BEGGAR_06"
msgstr "Jednog dana će svi, osim onih koji služe Redu, biti prisiljeni da nam se pridruže."

msgid "TXT_RANDOM_BEGGAR_07"
msgstr "Sada gledaj, ali znaš da će to jednog dana biti tvoje vlastito lice."

msgid "TXT_RANDOM_BEGGAR_08"
msgstr "Nema ništa iritantnije od gipsera s držanjem!"

msgid "TXT_RANDOM_BEGGAR_09"
msgstr "Red će brzo svladati vaš jadni front."

msgid "TXT_RANDOM_BEGGAR_10"
msgstr "Pazi se, površinaru. Znamo naše neprijatelje!"

msgid "TXT_RANDOM_PGUARD_01"
msgstr "Mi smo ruke sudbine. Ko izazove naš bijes, pronaći će zaborav!"

msgid "TXT_RANDOM_PGUARD_02"
msgstr "Red će očistiti svijet od slabih i korumpiranih!"

msgid "TXT_RANDOM_PGUARD_03"
msgstr "Poštujte volju gospodara!"

msgid "TXT_RANDOM_PGUARD_04"
msgstr "Dug život braći reda!"

msgid "TXT_RANDOM_PGUARD_05"
msgstr "Slobodna volja je iluzija koja veže slabe umove."

msgid "TXT_RANDOM_PGUARD_06"
msgstr "Moć je put ka slavi. Slijediti Red znači koračati tim putem!"

msgid "TXT_RANDOM_PGUARD_07"
msgstr "Zauzmi svoje mjesto među pravednima, pridruži nam se!"

msgid "TXT_RANDOM_PGUARD_08"
msgstr "Red štiti svoje."

msgid "TXT_RANDOM_PGUARD_09"
msgstr "Akoliti? Još nisu vidjeli punu slavu Reda."

msgid "TXT_RANDOM_PGUARD_10"
msgstr "Ako u toj patetičnoj ljusci tijela postoji ikakva čast, ući ćeš u naručje Reda."

msgid "TXT_RANDOMGOODBYE_1"
msgstr "Ćao!"

msgid "TXT_RANDOMGOODBYE_2"
msgstr "Hvala, zbogom!"

msgid "TXT_RANDOMGOODBYE_3"
msgstr "Vidimo se kasnije!"

# MAP33: After getting the hidden com unit in the tavern.
msgid "TXT_ILOG1"
msgstr "Zdravo? Komanda, komunikacijska jedinica je upravo aktivirana… Primam vizuelne i zvučne signale od… nekoga… Hej, ti, izađi odatle odmah… i ispusti kalež!"

# MAP02: After getting the com unit from Rowan and leaving his room.
msgid "TXT_ILOG2"
msgstr "Slušaj, ova komunikacijska jedinica mi govori da si 100% human. Dobio sam naredbu da te dovedem, ovdje je riječ o povjerenju. Izdaj me i plati. Oh, i usput, možeš me zvati Blackbird."

# MAP33: After getting the hidden com unit in the tavern.
msgctxt "strifeteaser"
msgid "TXT_ILOG2"
msgstr "Slušaj, ovaj kom-unit mi govori da si 100% human. Možda si jedan od nas, i možda možemo pokušati vjerovati jedni drugima. Uzmi ovo kao test: u guvernerovoj rezidenciji nalazi se bacač plamena. Donesi ga, i odvest ću te do nas."

# MAP02: On the bridge with the com unit.
msgid "TXT_ILOG3"
msgstr "Upati se prema staroj gradskoj vijećnici. Macil je dao izgraditi tunel koji nam omogućava da uđemo i izađemo neprimijećeni od akolita."

# MAP02: In town hall with the com unit.
msgid "TXT_ILOG4"
msgstr "Prođi kroz vrata s tvoje lijeve strane, zatim kroz ona s desne. Čuvar se zove Geoff. Reci mu da ti treba zlato."

msgctxt "strifeteaser"
msgid "TXT_ILOG5"
msgstr "Ne ulazi u gradsku vijećnicu. Više nije sigurno, otkrili su nas. Ubiji sve velike robote, \"Križare\" i ja ću te odvesti do nas."

# MAP33: In front of "Irale's shop" with the com unit and the Crusaders dead.
msgctxt "strifeteaser"
msgid "TXT_ILOG6"
msgstr "Vrata pored oružarnice će se otvoriti kad svi križari budu mrtvi. U skladištu se nalazi teleporter, upotrijebi ga i on će te dovesti do nas"

# MAP33: In front of "Irale's shop" with the com unit and the Crusaders alive.
msgctxt "strifeteaser"
msgid "TXT_ILOG7"
msgstr "Vrata pored oružarnice će se otvoriti kad svi krstaši budu mrtvi. U skladištu se nalazi teleporter, upotrijebi ga i on će te dovesti do nas."

# MAP33: Room with the flamethrower.
msgctxt "strifeteaser"
msgid "TXT_ILOG8"
msgstr "Ubij što više velikih robota, Krstaša, koliko možeš. Kad završiš, odvest ću te do Macila"

# MAP34: After leaving the teleporter.
msgctxt "strifeteaser"
msgid "TXT_ILOG9"
msgstr "Prođi kroz vrata i razgovaraj s Macilom."

# MAP02: After accepting "messy" chore and leaving Mourel's room.
msgid "TXT_ILOG10"
msgstr "Pronađi utičnicu na strujnom krugu i isključi je. Donesi nešto Guverneru kao dokaz. Pronađi MacGuffina i razgovaraj s njim."

# MAP02: After accepting "messy" chore and leaving Mourel's mansion.
msgid "TXT_ILOG11"
msgstr "Pronađi razvodnu kutiju na strujnom kablu i isključi je. Donesi Guverneru nešto kao dokaz. Pronađi MacGuffina i razgovaraj s njim. On je kod postrojenja za prečišćavanje otpadnih voda, u \"bum hole\", niz stepenice."

# MAP02: After destroying Front's power coupling.
msgid "TXT_ILOG13"
msgstr "Idiote! Isključio si napajanje za sklopove za ometanje koje koristimo da prikrijemo našu bazu od Reda. Idi do gradske vijećnice i eliminiši ekipu za skeniranje, odmah! Zatim se vrati kod guvernera i daj mu polomljeno kuplovanje."

# MAP02: After destroying Front's power coupling and killing all blue acolytes
# in the town hall.
msgid "TXT_ILOG14"
msgstr "OK, \"Ne vjeruj nikome\" je ime igre! Hajde da dobijemo taj zatvorski propusnik od guvernera. Odnesi mu polomljeno spojno vratilo."

# MAP02: After finding the broken power coupling.
msgid "TXT_ILOG15"
msgstr "Dobar potez! Guverner je lažljivac. Ovo je naše snage uparivanje. Koristimo ga da sakrijemo bazu od Reda. Vratimo mu ovo slomljeno uparivanje i nabavimo tu propusnicu."

# MAP05: After crossing the alarm green door.
msgid "TXT_ILOG18"
msgstr "Upotrijebi ključ čuvara da uđeš u blokove zatvorskih ćelija i pronađi način da oslobodiš zatvorenike."

# MAP05: After getting to Main Control.
msgid "TXT_ILOG19"
msgstr "Pronađi način da oslobodiš zatvorenike. Pronađi način da otvoriš prekidač ručnog skenera."

# MAP05: After cutting Wolenick's hand off.
msgid "TXT_ILOG20"
msgstr "Pronađi način da oslobodiš zatvorenike. Upotrijebi sudijinu ruku da aktiviraš prekidač skenera otiska prsta."

# MAP05: After setting the prisoners free.
msgid "TXT_ILOG21"
msgstr "Bravo, prijatelju. Dobar posao oslobađanja zatvorenika. Skoči na jedan od teleportera i on će te vratiti u bazu."

msgid "TXT_ILOG22"
msgstr "Uništi kristal snage koji pokreće mrežu koja napaja štitove Reda. Posjeti Wornera, špijuna kojeg smo regrutovali u skladištu elektrane."

# MAP04: After leaving Reactor Core.
msgid "TXT_ILOG24"
msgstr "Hajde da se izgubimo. Čeka nas još zabave."

# MAP02: After destroying the crystal in the Power Station.
msgid "TXT_ILOG25"
msgstr "Još jedna avantura prije nego što zapovjednik smatra da je sigurno napasti dvorac. Macil je dogovorio da ti Irale da zlato i obezbijedi obuku. Nakon što ga posjetiš, posjeti ljekara u gradu za snagu."

msgid "TXT_ILOG26"
msgstr "Posjeti Irale i ljekara u gradu za zlato i obuku, zatim pronađi kanalizaciju. Kreni uz rijeku preko puta Guvernerove palače."

# MAP06: Entrance.
msgid "TXT_ILOG28"
msgstr "Tražimo Werana, koji sebe naziva Kraljem Pacova. Siguran sam da je to i opisno i šareno."

# MAP06: After giving the guard's uniform to Weran.
msgid "TXT_ILOG33"
msgstr "Odnesi dijelove bacača plamena Iraleu. Isprazni rezervoar za reciklažu. Na dnu se nalazi skriveni ulaz u kanalizaciju. Kontrole za kapiju su tamo dolje, negdje. Uništi ih."

# MAP06: After destroying the gate controls.
msgid "TXT_ILOG37"
msgstr "Komandante, uspio je! Kapije su otvorene. Pošalji šok trupe i reci Macilu da ulazimo! Vraćamo se u bazu na frontu."

# MAP07: Entrace.
msgid "TXT_ILOG38"
msgstr "Pridružite se jurišu na dvorac. Pronađite i eliminišite programera. Imamo protivrečne izvještaje o njegovoj lokaciji. Jedan kaže da je u računarskoj sobi, drugi da se skriva u hramu na donjem nivou, a treći da je na kraju dugog hodnika."

# MAP09: Entrance.
msgid "TXT_ILOG45"
msgstr "Pronađi programera i ubij ga."

msgid "TXT_ILOG46"
msgstr "Potraži Orakulu i pitaj je o ostalim dijelovima Sigila. Orakula boravi u pograničnim predjelima, odmah izvan grada. Pređi rijeku, uputi se prema dvorcu i skreni lijevo kroz luk."

msgid "TXT_ILOG47"
msgstr "Potraži Orakulu i pitaj je o ostalim dijelovima Sigila. Hram Orakule nalazi se u pograničnim predjelima, na rubu grada."

# MAP10: After killing the Programmer, talking to Macil and moving a bit.
msgid "TXT_ILOG48"
msgstr "Potraži Orakulu i pitaj je o ostalim dijelovima Sigila. Uzmi svoju nagradu i idi do medicinskog tehničara i instruktora oružja za zdravlje i obuku. Hram Orakule nalazi se u pograničnim predjelima, na rubu grada."

# MAP11: Entrance to cave.
msgid "TXT_ILOG50"
msgstr "Potraži hram Orakla i pitaj ga o ostalim dijelovima Sigila. Evo ga. Snimam sve. Nije da nemam povjerenja da ćeš preživjeti. Samo ne smijemo dopustiti da Red kontrolira Sigil."

# MAP12: After talking to the Oracle.
msgid "TXT_ILOG56"
msgstr "Drugi dio leži u srcu grimizne i opekne kule. Tamo ćeš pronaći Biskupa. Biskup je vojni vođa Reda. Mi ga napadamo i postižemo dvostruki pogodak. Odnesi Orakulov žeton ključaru u pograničnim krajevima."

# MAP11: Officer's uniform room.
msgid "TXT_ILOG57"
msgstr "Biskup će biti strogo čuvan, pa zašto ne bismo ukrali uniformu i uklopili se? Pronađi biskupa. Kad ga uništiš, vrati se Oraklu."

# MAP17: Bailey → Upstairs.
msgid "TXT_ILOG59"
msgstr "Upravo sam dobio vijest da imamo doušnika unutar tvrđave. Krenimo prema bolnici. On tamo radi. Nakon toga pronađi biskupa i uništi ga. Kad bude mrtav, vrati se Orakulu."

# MAP19: Last room (southwestern).
msgid "TXT_ILOG64"
msgstr "Ne odustaj. Ovo je to. Pravo naprijed. Uskoči u teleporter do centralne administracije i uništi jezgro računara. To će ukloniti polje snage na ulazu u Biskupov toranj. Kad on umre, vrati se Orakulu."

# MAP15: After pressing the switch to reveal the computer.
msgid "TXT_ILOG70"
msgstr "Veoma impresivno. Hajde da ga raznesemo. To bi trebalo riješiti polje sile. Vratimo se na Bailey, pa onda na kulu i Biskupa."

# MAP16: After killing the Bishop.
msgid "TXT_ILOG74"
msgstr "Bravo, još jedan dio Sigila! Jesi li vidio onog čudnog duha koji je izašao iz tijela biskupa? Gdje sam to već vidio? Vratimo se Orakulu."

# MAP11: After killing the Bishop and going to MAP12's entrance.
msgid "TXT_ILOG76"
msgstr "Imam izvještaj da je spektralna energija koju smo pronašli blizu Bishopa također prisutna kod Orakla, budimo oprezni."

# MAP10: After killing Macil (Spectre) without having destroyed the converter
# in MAP24.
msgid "TXT_ILOG79"
msgstr "Richter je preuzeo zapovjedništvo nad našim snagama. Izgleda da nas je Macil sve vrijeme varao. Njegova je odanost zapravo bila prema Redu. Kakva zmija. Vratimo se Oraklu."

# MAP27: After killing the Loremaster with either Macil or the Oracle alive.
msgid "TXT_ILOG83"
msgstr "Još jedan komad Sigila. Mi smo korak bliže slobodi. A ti si korak bliže meni. Vratimo se Oraklu!"

# MAP27/MAP12: Remark at TXT_SUB_LOG85
msgid "TXT_ILOG85"
msgstr "Ti upravljaš moći potpunog Sigila. Šta kažeš da završimo priču. Hajde da vidimo šta je Majstor mudrosti štitio."

# MAP12: After killing the Oracle with Macil alive.
msgid "TXT_ILOG87"
msgstr "Pa, toliko o prognoziranju. Čekaj, Macil nas zove nazad. Hajdemo odavde na komad."

# MAP23: After talking with Richter and leaving his room.
msgid "TXT_ILOG89"
msgstr "Fabrika je pored rudnika. Richter sigurno misli na rudnike Degnina. Rudna iz Degnina je magnetična i eksplozivna, baš ono što treba za isključivanje polja sile. Hajde da uzmemo taj ključ iz katakomba, a onda idemo u rudnike po malo rude."

# MAP25: Entrance.
msgid "TXT_ILOG93"
msgstr "Fabrika je pored rudnika. Degninski rud je magnetičan i eksplozivan, baš ono što treba za gašenje polja snage. Uzmimo taj ključ iz katakomba, a onda silazimo po malo rude. Ovo moraju biti ruševine koje su Richterovi agenti tražili, pazi se."

# MAP25: After killing the Spectre.
msgid "TXT_ILOG95"
msgstr "Fabrika je pored rudnika. Degninski rud je magnetičan i eksplozivan, baš ono što treba za gašenje polja snage. Prijatelju, šta god da je ono protiv čega se borimo, to je više od samog Reda. Vraćamo se na zajedničko okupljalište, pa potom u rudnike. Trebamo rud."

# MAP14: Entrance.
msgid "TXT_ILOG96"
msgstr "Fabrika je pored rudnika. Degnin ruda je magnetna i eksplozivna, baš ono što treba za gašenje polja sile. Bez opuštanja budnosti, potražite nalazišta rude."

# MAP14: After crossing the entrance yard.
# (drone ≈ slave)
msgid "TXT_ILOG97"
msgstr "Ne spuštajući gardu, potražite nalazišta rude. Ove jadne duše su dronovi. Njihove sinapsne funkcije su ometene RC implantatima. Uništimo predajnik i oni su slobodni."

# MAP14: After James's room.
msgid "TXT_ILOG99"
msgstr "Fabrika je pored rudnika. Bez opuštanja budnosti, potraži nalazišta rude. Moj prijedlog je da rude baciš na polje sile, a zatim ga eksplodiraš; nastali pritisak trebao bi stvoriti magnetski plašt i ugasiti svjetla."

# MAP14: After destroying the transmitter.
msgid "TXT_ILOG100"
msgstr "Sada idemo u fabriku. Izađite iz rudnika i ne možete je promašiti. Pronađimo tu mašinu i isključimo je!"

# MAP20: Path to Conversion Chapel (MAP24).
# ("neural oscillation" or "brainwave")
msgid "TXT_ILOG102"
msgstr "Čitam ogromne distorzije neuronskih valova izravno ispred nas. Mislim da smo ga pronašli. Hajdemo unutra i isključimo ga!"

# MAP24: Converter room.
msgid "TXT_ILOG103"
msgstr "Upravo kad pomislim da smo sve vidjeli! Uđu kao ljudi, a izlaze… Ne želim ni razmišljati o tome. Uništite ovu užasnu stvar!"

# MAP24: After destroying the converter.
msgid "TXT_ILOG104"
msgstr "Macil je poludio. Upravo je svjesno poslao 200 ljudi na smrt. Želim osvetu! Za mrtve i za žive mrtve! Hajdemo se vratiti i saznati šta se dešava."

# MAP10: After killing Macil while having destroyed the converter in MAP24.
msgid "TXT_ILOG106"
msgstr "Fabrika vodi do \"laboratorija\", i iz nje dobivaju moćni potpis Sigila. Vraćamo se u fabriku i to je naš sljedeći korak ka slobodi."

# MAP16: Entrance → Central door.
msgid "TXT_ILOG120"
msgstr "Pronađi biskupa i uništi ga! Kad umre, vrati se Oraklu."

# MAP12?
msgid "TXT_ILOG122"
msgstr "Loremastorova laboratorija je iza teleportera koji se upravo otvorio. Hajde da saznamo o čemu je upravo brbljao. I naš sljedeći korak ka slobodi."

# MAP15: Computer destroyed + Room 1
msgid "TXT_ILOG211"
msgstr "Hajde, idemo odavde u pak. Polje sile je isključeno, idemo do biskupove kule. Kad ga ubiješ, vrati se Oraklu."

# MAP33?
msgid "TXT_ILOG1001"
msgstr "Pronađi svetište pored rijeke. Ukraji kalež iznutra. Donesi ga Harrisu u gostionici."

# MAP33?
msgid "TXT_ILOG1002"
msgstr "Pronađi guvernera. Razgovaraj s njim o svojoj nagradi."

# MAP02: After accepting Rowan's chore.
msgid "TXT_ILOG1003"
msgstr "Pronađi svetište uz rijeku. Unutra je zarobljen neko zvan Beldin. Ušutkaj ga i vrati njegov prsten Rowanu kao dokaz."

# MAP02: After getting the com unit from Rowan.
msgid "TXT_ILOG1004"
msgstr "Pronađi lokaciju Fronta i razgovaraj s Macilom."

# MAP02?
msgid "TXT_ILOG1005"
msgstr "Sпусти se niz stepenice, pronađi Macila i razgovaraj s njim."

# MAP03: After joining the Front.
msgid "TXT_ILOG1006"
msgstr "Posjeti Iralea, dobavljača oružja Fronta u gradu. On je iza vrata pored oružarnice. Zatim upotrijebi ključ koji ti je dao Macil da razgovaraš s guvernerom."

# MAP02: After accepting "messy" chore.
msgid "TXT_ILOG1007"
msgstr "Pronađi utičnicu na mreži i isključi je. Donesi nešto Guverneru kao dokaz."

# MAP02: After accepting "bloody" chore.
msgid "TXT_ILOG1008"
msgstr "Pronađi Derwina u skladištu elektrane. Ubij ga i donesi Mourelu njegovo uho."

# MAP03: After completing Mourel's chore.
msgid "TXT_ILOG1009"
msgstr "Upotrijebi propusnicu koju ti je dao Mourel da uđeš u zatvor. Kad si unutra, razgovaraj s upravnikom Montagom. Pronađi način da oslobodiš zatvorenike."

# MAP05
msgid "TXT_ILOG1010"
msgstr "Upotrijebi ključ čuvara da uđeš u blokove zatvorskih ćelija i pronađi način da oslobodiš zatvorenike."

# MAP03: After accepting Macil's second mission.
msgid "TXT_ILOG1011"
msgstr "Uništi kristal snage koji pokreće mrežu koja napaja štitove Reda. Posjeti Wornera, špijuna kojeg smo regrutovali u skladištu elektrane. Ne zaboravi posjetiti medicinskog tehničara i instruktora oružja prije nego što odeš."

# MAP04: After talking to Worner.
msgid "TXT_ILOG1012"
msgstr "Uništi kristal snage koji pokreće mrežu koja napaja štitove Reda. Upotrijebi I.D. da uđeš u elektranu. Možda bi htio provjeriti magacin iznad Wornera."

# MAP04: After talking to "Mr. Crispy".
msgid "TXT_ILOG1013"
msgstr "Uništi kristal snage koji pokreće mrežu za napajanje i štitove Reda. Idi i razgovaraj s Ketrickom u jezgri."

# MAP04: After talking to Sammis.
msgid "TXT_ILOG1014"
msgstr "Uništi kristal moći. Idi razgovarati s Ketrickom, podigni šetalište pomoću prekidača, a zatim upotrijebi ovu iskaznicu za lift."

msgid "TXT_ILOG1015"
msgstr "Pronađi ulaz u grad koji je čuvao Red. Otvori vrata i vrati uniformu stražara Weranu."

msgid "TXT_ILOG1016"
msgstr "Odnesi dijelove bacača plamena Irale. Pronađi vrata za održavanje kanalizacije. Pronađi i isprazni rezervoar za reciklažu unutar dvorca. Na dnu se nalazi skriveni ulaz u kanalizaciju. Negdje niz taj ulaz nalaze se kontrole za kapiju."

# MAP03: After destroying the gate controls and talking to Macil.
msgid "TXT_ILOG1017"
msgstr "Pridruži se jurišu na dvorac. Pronađi i eliminiši programera. Pronađi medicinskog tehničara i instruktora za oružje. Potroši sve što imaš. Ovo će biti pakleni okršaj."

msgid "TXT_ILOG1018"
msgstr "Upotrijebi ključ koji ti je dao lažni Programer da otvoriš ulaz u Programerovu tvrđavu. Mora da je tamo gdje se on skriva. Pronađi Programera i ubij ga."

# MAP10: After killing the Programmer and talking to Macil.
msgid "TXT_ILOG1019"
msgstr "Potraži Orakulu i pitaj je o ostalim dijelovima Sigila. Uzmi svoju nagradu i idi do medicinskog tehničara i instruktora oružja za zdravlje i obuku."

msgid "TXT_ILOG1020"
msgstr "Drugi dio leži u srcu grimizne i opekne kule. Tamo moraš pronaći Biskupa koji te čeka. Odnesi Orakulov žeton ključaru u pograničnim krajevima. Kad uništiš Biskupa, vrati se Orakulu."

# MAP11: After getting the Military ID from the keymaster.
msgid "TXT_ILOG1021"
msgstr "Pronađi karmesin i obsidijan toranj. Upotrijebi ID ključ koji ti je dao majstor ključeva da uđeš u toranj. Kad si unutra, moraš pronaći Biskupa. Kad si uništio Biskupa, vrati se Orakulu."

# MAP17: After talking to Quincy.
msgid "TXT_ILOG1022"
msgstr "Pronađi sigurnosni kompleks, probij se kroz njega i upotrijebi teleporter do centralne administracije. Uništi računarsko jezgro u centralnoj administraciji. To će uništiti polje snage na kuli biskupa. Kad biskup umre, vrati se Orakulu."

msgid "TXT_ILOG1023"
msgstr "Tvoj sljedeći izazov će testirati tvoj duh. Treći dio drži tvoj vođa. On je isti kao onaj koga ti šalje da ubiješ. Suočiti se s njim i odlučiti svoju sudbinu."

# MAP10: You chose to kill the Oracle.
msgid "TXT_ILOG1024"
msgstr "To je Oracle koji drži treći dio. Tu je tvoj izdajnik. Vratite se Oracleu i ubijte ga. Vratite mi se kad bude mrtav."

msgid "TXT_ILOG1025"
msgstr "Izrezali ste rak iz svog tijela, ali vaše srce i dalje kuca. Sada morate pronaći kirurga koji klanja i kontrolira vaš narod… Loremastera. Zaustavite ga i sljedeći dio bit će vaš."

msgid "TXT_ILOG1026"
msgstr "Sljedeće moraš pronaći kirurga koji masakrira i kontrolira tvoj narod… Loremastera. Zaustavi ga i sljedeći dio će biti tvoj. Upotrijebi teleporter koji sam otvorio da ga dostigneš. Kad umre, upotrijebi isti uređaj da se vratiš k meni."

# MAP12: You chose to kill Macil.
msgid "TXT_ILOG1027"
msgstr "Mudro si izabrao. Treći dio drži tvoj vođa. Uništi ono što se skriva u tvom srcu i vrati mi se."

# MAP10: After killing the Oracle and talking to Macil.
msgid "TXT_ILOG1028"
msgstr "Saznali smo da Red pretvara naš narod u biomehaničke vojnike. Pronađite objekt u kojem se to radi i zatvorite ga zauvijek! Pronađite Richtera u zajedničkom prostoru, blizu vodopada, i on će vam reći kako zaustaviti ovu zvjerstvo."

# MAP23: After talking with Richter.
msgid "TXT_ILOG1029"
msgstr "Da biste ušli u fabriku, potreban vam je ključ. Ukrali smo jedan, ali agent koji ga je imao nestaje u katakombama ispod zajedničkog prostora. Tamo dolje nešto odvodi naše ljude. Šta god da je, morate ga pronaći i vratiti ključ. Kad ga dobijete, fabrika je pored rudnika."

msgid "TXT_ILOG1101"
msgstr "Pronađi kalež u kapeli svetišta i odnesi ga Harrisu na gornji sprat tavernu."

msgid "TXT_ILOG1102"
msgstr "Pronađi guvernerovu rezidenciju i razgovaraj s guvernerom da dobiješ svoju nagradu"

msgid "TXT_ILOG1201"
msgstr "Čestitamo! Zaslužili ste našu zahvalnost. Posjetite medicinskog i instruktora oružja i oni će vas pripremiti za ono što vas čeka. Slobodno se prošetajte po bazi."

