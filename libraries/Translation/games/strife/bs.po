# (If you give the chalice away)
msgid "TXT_DLG_SCRIPT23_D18192_LOCAT"
msgstr "Lokirajte kovačnicu. Informacije koje sam vam upravo dao trebale bi vam pomoći da uđete u tajni sektor fabrike. Jedan od radnika u kovačnici može otvoriti vrata."

msgid "TXT_RPLY0_SCRIPT23_D18192_WHATC"
