msgid "TXT_DLG_SCRIPT17_D9096_OHHHI"
msgstr "Ohhh, znao sam da ćeš me to pitati. Pogledaj iza sebe. To je ulaz u biskupovu citadelu. Čuva ga polje sile koje se isključuje samo za službene posjetitelje, a ne za tebe."

msgid "TXT_RPLY0_SCRIPT17_D9096_IMUST"
