# SVE.WAD
# MAP22: C-shaped building → Master Smithy.
msgid "TXT_DLG_SCRIPT22_D0_IRUNT"
msgstr "Ja upravljam ovim mjestom. Moj posao je izrađivati sirovi dijelovi potrebni za Loremasterove dizajne robota. Ako niste ovdje na službenom poslu, bojim se da nemam vremena za razgovor."

