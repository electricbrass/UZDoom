# MAP01: Beldin.
msgid "TXT_DLG_SCRIPT01_D0_IDONT"
msgstr "Ne želim nikakve probleme, drži se podalje od mene. Već sam imao dovoljno nevolja zbog onoga što mi je taj gad Harris učinio. Obećao mi je novac, a umjesto toga moram se pripremiti na ispitivanje od strane Programera."

# MAP02: Guy next to Norwall Prison.
msgid "TXT_DLG_SCRIPT02_D0_ILLHE"
msgstr "Pomoći ću ti ako mi pomogneš. Pet komada zlata i reći ću sve što znam."

msgid "TXT_RPLY0_SCRIPT02_D0_HERES"
msgstr "Evo zlata."

# (This text is only four seconds on screen)
msgid "TXT_RYES0_SCRIPT02_D0_BESTE"
msgstr "Budite neprimjetni kad ubijate, nećete pokrenuti alarme."

# (Four seconds)
msgid "TXT_RNO0_SCRIPT02_D0_WELLI"
msgstr "Pa, neću ti ništa reći besplatno!"

msgid "TXT_DLG_SCRIPT02_D1516_HAVEY"
msgstr "Imaš li slučajno još pet zlatnih na sebi?"

msgid "TXT_RPLY0_SCRIPT02_D1516_5GOLD"
msgstr "5 zlata."

# (Four seconds)
msgid "TXT_RYES0_SCRIPT02_D1516_WELLP"
msgstr "Pa, otrovne strijele mogu odmah ubiti stražare i neće aktivirati alarme."

# (Four seconds)
msgid "TXT_RNO0_SCRIPT02_D1516_NOSIR"
msgstr "Ne, gospodine, neću vam ništa reći besplatno!"

msgid "TXT_DLG_SCRIPT02_D3032_YOUVE"
msgstr "Već si izvukao od mene posljednju tračicu!"

# MAP02: Irale.
msgid "TXT_DLG_SCRIPT02_D4548_WHATC"
msgstr "Šta mogu da vam donesem?"

msgid "TXT_RPLY0_SCRIPT02_D4548_ASSAU"
msgstr "Jurišna puška"

msgid "TXT_RYES0_SCRIPT02_D4548_HEREY"
msgstr "Evo."

msgid "TXT_RNO0_SCRIPT02_D4548_YOUCA"
msgstr "Ne možeš si to priuštiti sada."

msgid "TXT_RPLY1_SCRIPT02_D4548_CLIPO"
msgstr "Klip metaka"

msgid "TXT_RYES1_SCRIPT02_D4548_THANK"
msgstr "Hvala."

msgid "TXT_RNO1_SCRIPT02_D4548_COMEO"
msgstr "Hajde, 10 zlata."

msgid "TXT_RPLY2_SCRIPT02_D4548_AMMOB"
msgstr "Kutija za municiju"

msgid "TXT_RYES2_SCRIPT02_D4548_HERES"
msgstr "Evo ti municije."

msgid "TXT_RNO2_SCRIPT02_D4548_MAYBE"
msgstr "Možda neki drugi put."

# (After destroying the crystal in the Power Station)
msgid "TXT_DLG_SCRIPT02_D6064_GOODN"
msgstr "Dobre vijesti s fronta, za promjenu. Macil te je poslao na nagradu i obuku. Naložio mi je da ti ih dam."

msgid "TXT_RPLY0_SCRIPT02_D6064_THANK"
msgstr "Hvala."

msgid "TXT_RYES0_SCRIPT02_D6064_GLADT"
msgstr "Drago mi je što mogu pomoći."

msgid "TXT_DLG_SCRIPT02_D7580_ALLRI"
msgstr "U redu, evo nekoliko savjeta šta treba raditi: nemojte ometati Krstaše: kratki rafali iz vašeg jurišnog puška drže ga na meti."

msgid "TXT_RPLY0_SCRIPT02_D7580_ISTHA"
msgstr "Je li to sve?"

msgid "TXT_RYES0_SCRIPT02_D7580_LOOKY"
msgstr "Pogledaj, kasnije ćeš saznati više."

msgid "TXT_DLG_SCRIPT02_D9096_ITHIN"
msgstr "Mislim da mogu pretvoriti bacač plamena iz jednog od Krstaša za upotrebu od strane čovjeka. Oh, ima li još nešto što mogu nabaviti za tebe?"

msgid "TXT_RPLY0_SCRIPT02_D9096_FLAME"
msgstr "Bacač plamena."

msgid "TXT_RYES0_SCRIPT02_D9096_IKNEW"
msgstr "Znao sam da će to uspjeti! Evo, uzmi je na probnu vožnju!"

msgid "TXT_RNO0_SCRIPT02_D9096_LISTE"
msgstr "Slušaj, ne mogu napraviti ništa bez pravih dijelova!"

msgid "TXT_RPLY1_SCRIPT02_D9096_ASSAU"
msgstr "Jurišna puška"

msgid "TXT_RYES1_SCRIPT02_D9096_WELLH"
msgstr "Evo, gospodine!"

msgid "TXT_RNO1_SCRIPT02_D9096_OBVIO"
msgstr "Očigledno si to trenutno ne možeš priuštiti."

msgid "TXT_RPLY2_SCRIPT02_D9096_CLIPO"
msgstr "Klip metaka"

msgid "TXT_RYES2_SCRIPT02_D9096_THANK"
msgstr "Hvala."

msgid "TXT_RNO2_SCRIPT02_D9096_COMEO"
msgstr "Hajde, 10 zlata."

msgid "TXT_RPLY3_SCRIPT02_D9096_AMMOB"
msgstr "Kutija za municiju"

msgid "TXT_RYES3_SCRIPT02_D9096_HERES"
msgstr "Evo tvog streljiva."

msgid "TXT_RNO3_SCRIPT02_D9096_MAYBE"
msgstr "Možda neki drugi put. Zbogom!"

# (With flamethrower)
msgid "TXT_DLG_SCRIPT02_D10612_NOWTH"
msgstr "Sada kad imaš bacač plamena, ima li još nešto što mogu da ti nabavim?"

msgid "TXT_RPLY0_SCRIPT02_D10612_ASSAU"
msgstr "Jurišna puška"

msgid "TXT_RYES0_SCRIPT02_D10612_HEREY"
msgstr "Evo."

msgid "TXT_RNO0_SCRIPT02_D10612_YOUCA"
msgstr "Ne možeš si to priuštiti trenutno."

