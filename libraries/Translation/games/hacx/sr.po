msgctxt "doom hacx.hacx1"
msgid "QUITMSG1"
msgstr "Да ли су ти ови бугови превише тешки?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG"
msgstr ""
"Јеси ли сигуран да желиш\n"
"да се искључиш из акције?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG2"
msgstr "Покушаваш да престанеш? И зовеш себе хакером?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG3"
msgstr "Врати се овде пре него што ти пошаљем вирус кроз издувни колектор!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG4"
msgstr "Прави хакери никада не одступају из акције."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG5"
msgstr "Хајде! Још ниси видео најбољи део!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG6"
msgstr "Предајте се сада, и сајберпростор је мртав!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG7"
msgstr "ЏЕНИ шаље своје најбоље поздраве, кретену!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG8"
msgstr "Хмм. Толико о томе да будеш херој, Хакере."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG9"
msgstr "Шта? Ви бисте радије да се вратите у затвор?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG10"
msgstr "Требало је да узмем плаву пилулу."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG11"
msgstr "Име игре није Twitch n' Run!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG12"
msgstr "Без бриге. Спасавање света може да сачека, зар не?"

