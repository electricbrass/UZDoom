msgid "QUITMSG1"
msgstr "Sind diese Bugs zu viel für dich?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG"
msgstr ""
"Bist du sicher, dass du den\n"
"Stecker ziehen willst?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG2"
msgstr "Du willst gehen? Bist du wirklich ein Hacker?"

msgctxt "doom hacx.hacx1"
