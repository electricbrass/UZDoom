msgctxt "doom hacx.hacx1"
msgid "QUITMSG1"
msgstr "Är dessa bugs för svåra för dig?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG"
msgstr "Är du säker på att du inte vill vara med?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG2"
msgstr "Försöker du sluta? Och du kallar dig för hackare?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG3"
msgstr "Kom tillbaka innan jag skickar ett virus upp i ditt avgasrör!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG4"
msgstr "Riktiga hackare hoppar aldrig av."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG5"
msgstr "Kom igen! Du har inte sett det bästa ännu!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG6"
msgstr "Om du ger upp nu är cyberrymden död!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG7"
msgstr "GENIE skickar sina bästa hälsningar, skitstövel!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG8"
msgstr "Hmm. Så mycket för att vara en hjälte, Hacker."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG9"
msgstr "Vad? Vill du hellre gå tillbaka till pennan?"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG10"
msgstr "Du borde ha tagit det blå pillret."

msgctxt "doom hacx.hacx1"
msgid "QUITMSG11"
msgstr "Spelet heter inte \"Twitch n' Run\"!"

msgctxt "doom hacx.hacx1"
msgid "QUITMSG12"
